{
  "name": "@zapier/telegram-connector",
  "version": "0.2.12",
  "publishConfig": {
    "access": "public"
  },
  "description": "Agent-callable Telegram bot tools — send messages, media, locations, contacts, and polls; edit, delete, forward, copy, and pin messages; resolve chats, members, and files. Use when the user mentions Telegram or wants a bot to post, manage, or look up Telegram content.",
  "license": "Elastic-2.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./index.ts"
    }
  },
  "bin": {
    "@zapier/telegram-connector": "./cli.js"
  },
  "files": [
    "dist/",
    "cli.js",
    "*.ts",
    "scripts/",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "references/",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsup",
    "prepack": "tsup",
    "test": "vitest run"
  },
  "dependencies": {
    "@zapier/connectors-sdk": "^0.4.3",
    "zod": "^4.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "peerDependencies": {
    "@zapier/zapier-sdk-cli": ">=0.62.0 <1.0.0"
  },
  "keywords": [
    "telegram",
    "messaging",
    "chat",
    "bot",
    "zapier",
    "connector",
    "tools",
    "skills",
    "mcp",
    "agent",
    "ai",
    "automation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zapier/connectors.git",
    "directory": "apps/telegram"
  },
  "bugs": "https://github.com/zapier/connectors/issues",
  "devDependencies": {
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "homepage": "https://github.com/zapier/connectors/tree/main/apps/telegram"
}
