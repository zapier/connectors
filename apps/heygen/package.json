{
  "name": "@zapier/heygen-connector",
  "description": "Agent-callable HeyGen tools — generate AI avatar videos, translate and lip-sync videos, synthesize speech, and browse avatars and voices. Use when the user mentions HeyGen or wants to create, translate, or check the status of AI videos — including requests that don't name HeyGen, e.g. make an avatar video from a script, or translate a video to Spanish.",
  "license": "Elastic-2.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./index.ts"
    }
  },
  "bin": {
    "@zapier/heygen-connector": "./cli.js"
  },
  "files": [
    "dist/",
    "cli.js",
    "*.ts",
    "scripts/",
    "SKILL.md",
    "README.md",
    "NOTICE",
    "LICENSE",
    "references/"
  ],
  "scripts": {
    "build": "tsup",
    "prepack": "tsup",
    "test": "vitest run"
  },
  "dependencies": {
    "@zapier/connectors-sdk": "^0.4.3",
    "zod": "^4.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "peerDependencies": {
    "@zapier/zapier-sdk-cli": ">=0.62.0 <1.0.0"
  },
  "keywords": [
    "heygen",
    "zapier",
    "connector",
    "tools",
    "skills",
    "mcp",
    "agent",
    "ai",
    "automation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zapier/connectors.git",
    "directory": "apps/heygen"
  },
  "bugs": "https://github.com/zapier/connectors/issues",
  "homepage": "https://github.com/zapier/connectors/tree/main/apps/heygen",
  "devDependencies": {
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "version": "0.1.0",
  "publishConfig": {
    "access": "public"
  }
}
