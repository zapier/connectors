{
  "name": "@zapier/google-docs-connector",
  "private": true,
  "description": "Agent-callable Google Docs tools — create, read, export, and find documents; edit text, formatting, images, and page style. Use when the user mentions Google Docs or wants to create, read, search, or edit document content, even if they don't name Google Docs explicitly.",
  "license": "Elastic-2.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./index.ts"
    }
  },
  "bin": {
    "@zapier/google-docs-connector": "./cli.js"
  },
  "files": [
    "dist/",
    "cli.js",
    "*.ts",
    "scripts/",
    "preflight.sh",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "references/",
    "NOTICE.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "node cli.js build || bun cli.js build || true"
  },
  "dependencies": {
    "@zapier/connectors-sdk": "^0.1.0-experimental.20",
    "zod": "^4.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "peerDependencies": {
    "@zapier/zapier-sdk": ">=0.59.0 <1.0.0"
  },
  "keywords": [
    "google-docs",
    "documents",
    "docs",
    "word-processing",
    "text-editing",
    "google-workspace",
    "zapier",
    "connector",
    "tools",
    "skills",
    "mcp",
    "agent",
    "ai",
    "automation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zapier/connectors.git",
    "directory": "apps/google-docs"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
