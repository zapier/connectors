{
  "name": "@zapier/pipedrive-connector",
  "version": "0.1.1",
  "publishConfig": {
    "access": "public"
  },
  "description": "Agent-callable Pipedrive tools for deals, persons, organizations, activities, leads, products, and notes.",
  "license": "Elastic-2.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./index.ts"
    }
  },
  "bin": {
    "@zapier/pipedrive-connector": "./cli.js"
  },
  "files": [
    "dist/",
    "cli.js",
    "*.ts",
    "scripts/",
    "preflight.sh",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "references/",
    "NOTICE.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "node cli.js build || bun cli.js build || true"
  },
  "dependencies": {
    "@zapier/connectors-sdk": "^0.1.0",
    "zod": "^4.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "peerDependencies": {
    "@zapier/zapier-sdk": ">=0.59.0 <1.0.0"
  },
  "keywords": [
    "pipedrive",
    "crm",
    "sales",
    "deals",
    "zapier",
    "connector",
    "tools",
    "skills",
    "mcp",
    "agent",
    "ai",
    "automation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zapier/connectors.git",
    "directory": "apps/pipedrive"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
