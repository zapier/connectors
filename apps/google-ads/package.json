{
  "name": "@zapier/google-ads-connector",
  "description": "Agent-callable Google Ads tools — search campaigns, ad groups, and ads via GAQL, build performance reports, manage campaign status and budgets, and set up conversion tracking. Use when the user mentions Google Ads or wants to read or manage advertising campaigns, budgets, or reporting — even if they don't name Google Ads explicitly.",
  "license": "Elastic-2.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./index.ts"
    }
  },
  "bin": {
    "@zapier/google-ads-connector": "./cli.js"
  },
  "files": [
    "dist/",
    "cli.js",
    "*.ts",
    "scripts/",
    "SKILL.md",
    "README.md",
    "NOTICE",
    "LICENSE",
    "references/"
  ],
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "@zapier/connectors-sdk": "^0.2.3",
    "zod": "^4.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "peerDependencies": {
    "@zapier/zapier-sdk": ">=0.59.0 <1.0.0"
  },
  "keywords": [
    "google-ads",
    "zapier",
    "connector",
    "tools",
    "skills",
    "mcp",
    "agent",
    "ai",
    "automation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zapier/connectors.git",
    "directory": "apps/google-ads"
  },
  "version": "0.2.2",
  "publishConfig": {
    "access": "public"
  }
}
